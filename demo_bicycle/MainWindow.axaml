<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="demo_bicycle.MainWindow"
        Title="Авторизация"
		Icon="Icon/icon.png">

	<StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
	    <TextBox Name="LoginTextBox" Watermark="Введите логин" Margin="5" />
		<TextBox Name="PasswordTextBox" Watermark="Введите пароль" Margin="5" />
		<Button Content="Войти" Name="Auth" Click="Auth_Click" Margin="5"/>
		<Button Content="Войти как гость" Name="Guest" Click="Guest_Click" Margin="5"/>
		
	</StackPanel>


</Window>
